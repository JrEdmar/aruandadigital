APP_NAME="Aruanda Digital"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-projeto.vercel.app

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# -----------------------------------------------------------------------
# Banco de dados — use Neon (https://neon.tech) ou Supabase para Vercel
# -----------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

# -----------------------------------------------------------------------
# Sessão e Cache — cookie/array são ideais para serverless
# -----------------------------------------------------------------------
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=array

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# -----------------------------------------------------------------------
# E-mail (opcional)
# -----------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="contato@aruandadigital.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------
# OAuth Social (opcional)
# -----------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

VITE_APP_NAME="${APP_NAME}"
